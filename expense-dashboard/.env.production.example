APP_NAME=Ledger
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://ledger.jjaguilar.dev

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=sqlite
DB_DATABASE=/var/www/ledger/expense-dashboard/database/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

# MAIL_MAILER is deliberately left as "log" here - no transactional mail
# provider is configured yet, so password-reset/verification emails will
# only ever land in storage/logs/laravel.log, not a real inbox. Flagged in
# the Day 23 deploy checklist; swap to a real driver (ses/postmark/smtp)
# once a provider is chosen.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@ledger.jjaguilar.dev"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Required - the AI Overview feature (see PROJECT_NOTES.md Day 21/22) calls
# the real Anthropic API using this key. Never commit the real value; this
# file is a template, the real .env on the server is gitignored.
ANTHROPIC_API_KEY=

VITE_APP_NAME="${APP_NAME}"
