APP_NAME=Ledger
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://ledger.jjaguilar.dev

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=sqlite
DB_DATABASE=/var/www/ledger/expense-dashboard/database/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

# Password-reset/verification emails are sent via Resend
# (https://resend.com) - closes the mail gap flagged in Day 23.
# "ledger.jjaguilar.dev" is verified as a sending domain there.
MAIL_MAILER=resend
MAIL_FROM_ADDRESS="hello@ledger.jjaguilar.dev"
MAIL_FROM_NAME="${APP_NAME}"

# Required - real key goes in the gitignored .env on the server, never
# committed.
RESEND_API_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Required - the AI Overview feature (see PROJECT_NOTES.md Day 21/22) calls
# the real Anthropic API using this key. Never commit the real value; this
# file is a template, the real .env on the server is gitignored.
ANTHROPIC_API_KEY=

VITE_APP_NAME="${APP_NAME}"
